# AWS / S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-2
AWS_S3_BUCKET_NAME=your-bucket-name

# MongoDB
MONGODB_URI=mongodb://username:password@host:27017/database?ssl=true&replicaSet=replica-set&authSource=admin

# JWT & crypto — MUST match the Next.js deployment's secrets
JWT_ACCESS_SECRET=your-jwt-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars
CRYPTO_SECRET=your-crypto-secret-min-32-chars

# App
MAX_FILES=50
CRON_SECRET=your-cron-secret
PORT=3001
NODE_ENV=development
